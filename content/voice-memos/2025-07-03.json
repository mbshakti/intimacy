{"chunks":[{"start":0,"end":1.44,"text":"5 characteristics that"},{"start":1.486,"end":2.508,"text":"play must have"},{"start":2.543,"end":4.238,"text":"Johan Huizinga, a"},{"start":4.331,"end":5.724,"text":"Dutch historian and"},{"start":5.805,"end":7.512,"text":"cultural theorist, discussed"},{"start":7.57,"end":8.429,"text":"the importance of"},{"start":8.487,"end":9.3,"text":"the play element"},{"start":9.358,"end":10.124,"text":"of culture and"},{"start":10.182,"end":11.517,"text":"society in his"},{"start":11.575,"end":12.922,"text":"book Homo Ludens."},{"start":13.874,"end":15.372,"text":"In it, Huizinga"},{"start":15.488,"end":17.345,"text":"identifies 5 characteristics"},{"start":17.391,"end":18.123,"text":"that play must"},{"start":18.169,"end":19.911,"text":"have: Play is"},{"start":19.992,"end":20.967,"text":"free, is in"},{"start":21.037,"end":22.883,"text":"fact freedom. Play"},{"start":22.953,"end":24.067,"text":"is not \"ordinary\""},{"start":24.137,"end":25.298,"text":"or \"real\" life."},{"start":25.878,"end":26.9,"text":"Play is distinct"},{"start":26.958,"end":28.165,"text":"from \"ordinary\" life"},{"start":28.247,"end":28.816,"text":"both as to"},{"start":28.908,"end":30.801,"text":"locality and duration."},{"start":31.474,"end":32.914,"text":"Play creates order,"},{"start":33.076,"end":34.504,"text":"is order. Play"},{"start":34.551,"end":36.431,"text":"demands order absolute"},{"start":36.466,"end":38.289,"text":"and supreme. Play"},{"start":38.359,"end":39.102,"text":"is connected with"},{"start":39.171,"end":40.553,"text":"no material interest,"},{"start":40.622,"end":41.528,"text":"and no profit"},{"start":41.586,"end":42.143,"text":"can be gained"},{"start":42.178,"end":43.653,"text":"from it. This"},{"start":43.722,"end":44.338,"text":"made me think"},{"start":44.431,"end":45.742,"text":"of bot makers."}]}