{"chunks":[{"start":0,"end":1.207,"text":"Large AI labs"},{"start":1.265,"end":2.334,"text":"are oriented toward"},{"start":2.38,"end":4.075,"text":"generality. They build"},{"start":4.122,"end":4.992,"text":"systems that must"},{"start":5.039,"end":6.095,"text":"work reasonably well"},{"start":6.165,"end":7.291,"text":"for many users,"},{"start":7.57,"end":9.033,"text":"across many domains,"},{"start":9.358,"end":10.681,"text":"under many conditions."},{"start":11.378,"end":12.841,"text":"Independent bot makers"},{"start":13.015,"end":13.723,"text":"often have a"},{"start":13.781,"end":14.919,"text":"narrower and stranger"},{"start":14.988,"end":16.347,"text":"goal. They are"},{"start":16.382,"end":17.171,"text":"not asking how"},{"start":17.241,"end":17.578,"text":"to make a"},{"start":17.636,"end":19.029,"text":"model broadly useful."},{"start":19.412,"end":20.503,"text":"They are asking:"},{"start":20.712,"end":21.142,"text":"How do you"},{"start":21.212,"end":21.827,"text":"make this one"},{"start":21.873,"end":23.615,"text":"character feel consistent?"},{"start":24.056,"end":24.486,"text":"How do you"},{"start":24.555,"end":24.892,"text":"get it to"},{"start":24.962,"end":25.681,"text":"respond in a"},{"start":25.739,"end":26.506,"text":"way that feels"},{"start":26.564,"end":28.201,"text":"believable? Does the"},{"start":28.259,"end":29.443,"text":"character hold together"},{"start":29.524,"end":30.918,"text":"over time? Does"},{"start":30.952,"end":31.893,"text":"it feel right?"},{"start":33.007,"end":34.145,"text":"These aren’t scientific"},{"start":34.192,"end":35.097,"text":"questions in the"},{"start":35.144,"end":36.514,"text":"strict sense, they’re"},{"start":36.537,"end":38.487,"text":"aesthetic judgments. There"},{"start":38.534,"end":39.172,"text":"is a freedom"},{"start":39.253,"end":40.124,"text":"at the margins"},{"start":40.252,"end":41.459,"text":"that institutions do"},{"start":41.541,"end":42.771,"text":"not easily permit."},{"start":43.468,"end":44.954,"text":"In open ecosystems"},{"start":45.105,"end":46.637,"text":"like Pygmalion and"},{"start":46.684,"end":47.276,"text":"the tools that"},{"start":47.334,"end":48.774,"text":"surround it, people"},{"start":48.82,"end":49.656,"text":"can run models"},{"start":49.737,"end":50.968,"text":"locally and build"},{"start":51.038,"end":51.769,"text":"according to their"},{"start":51.816,"end":53.36,"text":"desires. And it’s"},{"start":53.406,"end":54.532,"text":"those judgments that"},{"start":54.567,"end":55.275,"text":"seem to drive"},{"start":55.31,"end":56.378,"text":"the most passionate"},{"start":56.587,"end":58.793,"text":"and sustained experimentation."}]}